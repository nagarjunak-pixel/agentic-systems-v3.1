{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Business_Outcome_Metric",
  "type": "object",
  "properties": {
    "timestamp": { "type": "number" },
    "task_id": { "type": "string" },
    "agent_id": { "type": "string" },
    "outcome_type": { "type": "string" },
    "success": { "type": "boolean" },
    "roi_value_usd": { "type": "number", "minimum": 0.0 },
    "cost_usd": { "type": "number", "minimum": 0.0 },
    "efficiency_ratio": { "type": "number" },
    "details": {
      "type": "object"
    }
  },
  "required": ["timestamp", "task_id", "agent_id", "outcome_type", "success", "roi_value_usd", "cost_usd", "efficiency_ratio"]
}
